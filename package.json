{
  "name": "hak53q-template",
  "private": true,
  "version": "0.1.0",
  "description": "Standalone Nextra v4 docs site rebuilt with the App Router and content directory.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "npx serve@latest out",
    "typecheck": "tsc --noEmit",
    "postbuild": "pagefind --site .next/server/app --output-path public/_pagefind"
  },
  "dependencies": {
    "next": "^15.0.0",
    "nextra": "^4.0.0",
    "nextra-theme-docs": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "pagefind": "^1.5.2",
    "typescript": "^5.0.0"
  }
}